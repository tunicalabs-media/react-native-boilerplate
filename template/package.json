{
  "name": "nativeboilerplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android-run-release": "npx react-native run-android --mode release",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "start-reset": "react-native start --reset-cache",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "test": "jest",
    "check-lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "assets": "npx react-native-asset",
    "pods": "cd ios && pod install && cd ..",
    "pods-clear": "cd ios && pod deintegrate && rm -rf Pods && rm -rf build && rm -rf Pods Podfile.lock ~/Library/Developer/Xcode/DerivedData && pod install --repo-update && cd ..",
    "android-clean": "cd android && ./gradlew clean",
    "android-signingReport": "cd android && ./gradlew signingReport",
    "android-uninstall": "cd android && ./gradlew uninstallAll",
    "android-bundle": "npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android-apk-debug": "npm run android-bundle && cd android && ./gradlew clean && ./gradlew assembleDebug",
    "android-apk-release": "npm run android-bundle && cd android && ./gradlew clean && ./gradlew assembleRelease",
    "android-release": "npm run android-bundle && cd android && ./gradlew clean && npx react-native build-android --mode=release",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native/new-app-screen": "^0.86.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@reduxjs/toolkit": "^2.12.0",
    "react": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-pager-view": "^8.0.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-simple-toast": "^3.3.2",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-svg": "^15.15.5",
    "react-native-tab-view": "^4.3.1",
    "react-native-unistyles": "^3.2.5",
    "react-redux": "^9.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "prettier": "^3.8.4",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
